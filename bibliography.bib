@mastersthesis{royer2019pitch,
  author = {Royer, Théo},
  title  = {Pitch-shifting algorithm design and applications in music},
  school = {KTH Royal Institute of Technology, School of Electrical Engineering and Computer Science},
  year   = {2019},
  type   = {Master’s thesis},
  url    = {https://www.diva-portal.org/smash/get/diva2:1381398/FULLTEXT01.pdf},
  isbn   = {TRITA-EECS-EX; 2019:674},
  annote = {The main focus of this paper is to implement and analyze several of the most prominent pitch-shifting techniques. While not rigorously peer-reviewed, this master’s thesis is published in the DiVA portal, an open-access repository governed by approximately 50 Swedish universities, and has been reviewed by faculty advisors in relevant fields. One particularly helpful section is Chapter 3, which analyses modern time-domain and frequency-domain pitch-shifting algorithms. The author compares their advantages and limitations, including computational complexity, latency, and ability to handle polyphonic signals. Additionally, Sections 2.1, 2.2, and 2.3 provide the mathematical foundation underlying most pitch-shifting methods. This thesis will serve as an important reference moving forward, as it establishes a clear and concise basis for choosing and implementing an algorithm.}
}

@article{dolson1986phase,
  author    = {Dolson, Mark},
  title     = {The phase vocoder: A tutorial},
  journal   = {Computer Music Journal},
  volume    = {10},
  number    = {4},
  pages     = {14--27},
  year      = {1986},
  publisher = {The MIT Press},
  annote    = {The main focus of this paper is to provide an approachable explanation of the phase vocoder algorithm. With over 600 citations on Google Scholar and publication by The MIT Press, it is a foundational work in the field of digital signal processing. The paper presents the algorithm in two forms: one based on a filter bank of bandpass filters and another based on the Fast Fourier Transform. The latter is more relevant to this project, as it offers a computationally efficient method for performing pitch shifting on an input signal. A section of great interest is the \textit{Pitch Transposition} section which describes a procedure for lowering the pitch of a signal without changing the duration of the signal. Moreover, the paper provides additional information such as how to properly obtain a correct window size when sampling a signal,  sampling theory, and how to synthesize a final signal. }
}

